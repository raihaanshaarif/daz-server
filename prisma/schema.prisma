// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            Int        @id @default(autoincrement())
  name          String
  email         String     @unique
  password      String?
  role          Role       @default(USER)
  status        UserStatus @default(ACTIVE)
  isVerified    Boolean    @default(false)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  posts         Post[]
  contacts      Contact[]
  tasksAssigned Task[]     @relation("TaskAssigner")
  tasksReceived Task[]     @relation("TaskAssignee")
  orders        Order[]
}

model Post {
  id         Int      @id @default(autoincrement())
  title      String
  content    String
  thumbnail  String?
  isFeatured Boolean  @default(false)
  tags       String[]
  views      Int      @default(0)
  authorId   Int
  author     User     @relation(fields: [authorId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Country {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  code      String? // ISO country code like "US", "CA", etc.
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contacts Contact[]
}

model Contact {
  id               Int       @id @default(autoincrement())
  name             String
  email            String
  designation      String    @default("Unknown")
  company          String
  domain           String?
  countryId        Int?
  companyLinkedin  String?
  personalLinkedin String?
  status           Status    @default(NOT_CONTACTED)
  note             String?
  authorId         Int
  author           User      @relation(fields: [authorId], references: [id])
  lastContactedAt  DateTime?
  lastRepliedAt    DateTime?
  nextFollowUpAt   DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  country          Country?  @relation(fields: [countryId], references: [id])
}

model Task {
  id           Int      @id @default(autoincrement())
  title        String
  description  String?
  targetValue  Int
  assignedById Int
  assignedToId Int
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assignedBy User           @relation("TaskAssigner", fields: [assignedById], references: [id])
  assignedTo User           @relation("TaskAssignee", fields: [assignedToId], references: [id])
  dailyLogs  TaskDailyLog[]
}

model TaskDailyLog {
  id     Int  @id @default(autoincrement())
  taskId Int
  task   Task @relation(fields: [taskId], references: [id])

  date        DateTime
  targetValue Int
  achieved    Int      @default(0)

  performance Float?
  status      TaskStatus

  createdAt DateTime @default(now())

  @@unique([taskId, date])
}

enum TaskStatus {
  PENDING
  COMPLETED
  FAILED
}

enum Status {
  NOT_CONTACTED // Email not sent yet

  CONTACTED // Initial email sent
  FOLLOW_UP_SENT // Follow-up sent

  ENGAGED // Buyer replied / conversation active
  INTERESTED // Expressed sourcing interest
  QUALIFIED // Meets MOQ, price, product fit

  CATALOG_SENT // Profile / catalog shared

  SAMPLE_REQUESTED // Sample requested
  SAMPLE_SENT // Sample dispatched

  PRICE_NEGOTIATION // Price discussion ongoing

  CLOSED_WON // First order confirmed (PO received)
  REPEAT_BUYER // Buyer placed 2+ orders

  NON_RESPONSIVE // Stopped replying
  REENGAGED // Replied after inactive period
  DORMANT // Long inactive (60+ days)

  NOT_INTERESTED // Explicitly said no
  INVALID // Wrong email / bounced
  DO_NOT_CONTACT // Asked to stop communication
}

enum Role {
  SUPER_ADMIN
  ADMIN
  USER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BLOCK
}

model Buyer {
  id     Int     @id @default(autoincrement())
  name   String  @unique
  brand  String?
  orders Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Factory {
  id     Int     @id @default(autoincrement())
  name   String  @unique
  orders Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id Int @id @default(autoincrement())

  orderNumber String    @unique
  shipDate    DateTime?
  dept        String?
  style       String?
  color       String?
  lot         String?

  quantity   Int
  price      Float
  totalPrice Float

  factoryUnitPrice  Float?
  totalFactoryPrice Float?

  dazCommission      Float?
  discountFactory    Float?
  discountFromDaz    Float?
  discountRemark     String?
  finalDazCommission Float?

  paymentTerm String?

  yarnBooking    DateTime?
  labdipYarndip  DateTime?
  printStrikeOff DateTime?
  ppSample       DateTime?
  bulkFabric     DateTime?
  cutting        DateTime?
  printing       DateTime?
  swing          DateTime?
  finishing      DateTime?
  shipmentSample DateTime?
  inspection     DateTime?
  exFactory      DateTime?

  overallRemarks String?

  commissionStatus CommissionStatus @default(PENDING)
  commissionAmount Float?

  buyerId     Int
  factoryId   Int
  createdById Int

  buyer     Buyer   @relation(fields: [buyerId], references: [id])
  factory   Factory @relation(fields: [factoryId], references: [id])
  createdBy User    @relation(fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderNumber])
}

enum CommissionStatus {
  PENDING
  PAID
}
