// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            Int        @id @default(autoincrement())
  name          String
  email         String     @unique
  password      String?
  role          Role       @default(USER)
  status        UserStatus @default(ACTIVE)
  isVerified    Boolean    @default(false)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  posts         Post[]
  contacts      Contact[]
  tasksAssigned Task[]     @relation("TaskAssigner")
  tasksReceived Task[]     @relation("TaskAssignee")
}

model Post {
  id         Int      @id @default(autoincrement())
  title      String
  content    String
  thumbnail  String?
  isFeatured Boolean  @default(false)
  tags       String[]
  views      Int      @default(0)
  authorId   Int
  author     User     @relation(fields: [authorId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Country {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  code      String? // ISO country code like "US", "CA", etc.
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contacts Contact[]
}

model Contact {
  id               Int      @id @default(autoincrement())
  name             String
  email            String
  designation      String   @default("Unknown")
  company          String
  domain           String?
  countryId        Int?
  companyLinkedin  String?
  personalLinkedin String?
  status           Status   @default(NOT_SENT)
  note             String?
  authorId         Int
  author           User     @relation(fields: [authorId], references: [id])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  country          Country? @relation(fields: [countryId], references: [id])
}

model Task {
  id           Int      @id @default(autoincrement())
  title        String
  description  String?
  targetValue  Int
  assignedById Int
  assignedToId Int
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assignedBy User           @relation("TaskAssigner", fields: [assignedById], references: [id])
  assignedTo User           @relation("TaskAssignee", fields: [assignedToId], references: [id])
  dailyLogs  TaskDailyLog[]
}

model TaskDailyLog {
  id     Int  @id @default(autoincrement())
  taskId Int
  task   Task @relation(fields: [taskId], references: [id])

  date        DateTime
  targetValue Int
  achieved    Int      @default(0)

  performance Float?
  status      TaskStatus

  createdAt DateTime @default(now())

  @@unique([taskId, date])
}

enum TaskStatus {
  PENDING
  COMPLETED
  FAILED
}

enum Status {
  NOT_SENT
  NEW
  CONTACTED
  RESPONDED
  QUALIFIED
  NEGOTIATING
  CLOSED_WON
  CLOSED_LOST
}

enum Role {
  SUPER_ADMIN
  ADMIN
  USER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BLOCK
}
